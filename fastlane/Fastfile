default_platform(:android)

platform :android do
  desc "Generate localized Google Play screenshots via the UI-test harness"
  desc ""
  desc "Builds the debug + androidTest APKs, then drives the app through"
  desc "fastlane screengrab (see fastlane/Screengrabfile): the"
  desc "ScreenshotTest flow runs on the offline UITestRegistry harness,"
  desc "seeds a group + conversation, and captures every screen in each"
  desc "configured locale. Output → fastlane/metadata/android/<locale>/"
  desc "images/phoneScreenshots (git-ignored). Requires a connected"
  desc "device or running emulator. Upload separately with upload_all."
  lane :screenshots do
    gradle(task: "assembleDebug assembleDebugAndroidTest")
    capture_android_screenshots

    # Google Play rejects screenshots whose long side is more than 2×
    # the short side. Tall modern emulators (e.g. Pixel 9a, 1080×2424 =
    # 2.24:1) exceed that, so pad each over-tall shot with white side
    # margins down to ~1.95:1 — content untouched. sips is macOS-only;
    # screenshots are generated locally on macOS.
    if `which sips`.strip.empty?
      UI.important("sips not found — screenshots not padded; Play may reject images over 2:1.")
    else
      Dir.glob("fastlane/metadata/android/*/images/phoneScreenshots/*.png").each do |png|
        h = `sips -g pixelHeight '#{png}'`[/pixelHeight: (\d+)/, 1].to_i
        w = `sips -g pixelWidth '#{png}'`[/pixelWidth: (\d+)/, 1].to_i
        next if h.zero? || w.zero? || h.to_f / w < 2.0
        target_w = (h / 1.95).ceil
        sh("sips --padToHeightWidth #{h} #{target_w} --padColor FFFFFF '#{png}'", log: false)
      end
      UI.success("Padded over-tall screenshots to a Play-compliant aspect ratio.")
    end
  end

  desc "First release: upload a signed AAB + all listing assets to internal"
  desc ""
  desc "Use this for the very first upload — supply can't push listing"
  desc "metadata until a build (version code) exists on a track. Uploads"
  desc "the AAB to the internal track together with the descriptions,"
  desc "icon, feature graphic, screenshots, and changelog in one run."
  desc ""
  desc "  AAB_PATH — path to a signed .aab (default: the bundleRelease"
  desc "             output). SUPPLY_JSON_KEY — service-account key."
  desc ""
  desc "The release is created as a draft; roll it out in the console."
  lane :deploy_internal do
    aab = ENV["AAB_PATH"] || "app/build/outputs/bundle/release/app-release.aab"
    upload_to_play_store(
      package_name: "app.onym.android",
      track: "internal",
      aab: aab,
      metadata_path: "./fastlane/metadata/android",
      skip_upload_apk: true,
      skip_upload_metadata: false,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      skip_upload_changelogs: false,
      release_status: "draft"
    )
  end

  desc "Upload Play store listing text (title/descriptions) — no binary"
  desc ""
  desc "Reads the Google Play service-account key from the environment:"
  desc "  SUPPLY_JSON_KEY       — path to the .json key file  (or…)"
  desc "  SUPPLY_JSON_KEY_DATA  — the JSON contents, inline   (use in CI)"
  desc ""
  desc "Requires at least one existing release on the internal track"
  desc "(supply ties metadata upload to a version code) — run"
  desc "deploy_internal first. Pushes listing text only."
  lane :upload_metadata do
    upload_to_play_store(
      package_name: "app.onym.android",
      track: "internal",
      metadata_path: "./fastlane/metadata/android",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: false,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )
  end

  desc "Upload Play store listing text + images + screenshots — no binary"
  desc ""
  desc "Same service-account env vars as upload_metadata, and likewise"
  desc "requires an existing internal-track release (run deploy_internal"
  desc "first). Pushes the committed listing text, icon, feature graphic,"
  desc "and the generated screenshots (run the screenshots lane first)."
  lane :upload_all do
    upload_to_play_store(
      package_name: "app.onym.android",
      track: "internal",
      metadata_path: "./fastlane/metadata/android",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: false,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      skip_upload_changelogs: true
    )
  end
end
