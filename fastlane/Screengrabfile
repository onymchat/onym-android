# fastlane screengrab — localized Google Play screenshots, generated by
# driving the app through the offline UITestRegistry harness
# (app/src/androidTest/.../uitests/ScreenshotTest.kt).
#
# Output lands directly in the supply metadata tree
# (fastlane/metadata/android/<locale>/images/phoneScreenshots), so the
# upload_all lane picks them up. The PNGs are git-ignored — regenerate
# on demand with `fastlane screenshots`.

app_package_name('app.onym.android')

# Debug app + androidTest APKs (built by the screenshots lane).
app_apk_path('app/build/outputs/apk/debug/app-debug.apk')
tests_apk_path('app/build/outputs/apk/androidTest/debug/app-debug-androidTest.apk')

# Only the dedicated screenshot flow — not the whole instrumented suite.
use_tests_in_classes(['app.onym.android.uitests.ScreenshotTest'])
test_instrumentation_runner('androidx.test.runner.AndroidJUnitRunner')

# The app is localized for English + Russian (see res/values-ru).
# Play locale codes; en-US → default resources, ru-RU → values-ru.
locales(['en-US', 'ru-RU'])
ending_locale('en-US')

# Land screenshots in the supply metadata structure.
output_directory('fastlane/metadata/android')
clear_previous_screenshots(true)

reinstall_app(false)
use_timestamp_suffix(false)
exit_on_test_failure(true)
