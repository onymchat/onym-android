<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only manifest additions for fastlane screengrab.

  CHANGE_CONFIGURATION lets screengrab's LocaleUtil switch the in-app
  locale between capture passes (en-US / ru-RU). DUMP is used by some
  screenshot strategies. Both are protected permissions granted at
  runtime by screengrab via `adb shell pm grant`; they exist only in
  the debug variant and never ship in release.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission
        android:name="android.permission.CHANGE_CONFIGURATION"
        tools:ignore="ProtectedPermissions" />
    <uses-permission
        android:name="android.permission.DUMP"
        tools:ignore="ProtectedPermissions" />

</manifest>
